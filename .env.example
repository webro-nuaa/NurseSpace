# ============================================
# NurseSpace v1.2.1 — 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ⚠️ .env 包含敏感信息，绝不能提交到版本控制
# ⚠️ 生产环境必须使用随机强密码
# ============================================

# ---------- 必填项（生产环境必须修改）----------

# Flask 密钥（用于 session 签名）
# 生成方法: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# JWT 密钥（用于 Token 签名）
# 生成方法: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-another-random-string

# 加密密钥（用于加密 DB 中存储的 AI API Key）
# 生成方法: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-to-a-fernet-key

# MySQL 数据库密码
MYSQL_PASSWORD=change-me-to-a-strong-db-password

# Redis 密码
REDIS_PASSWORD=change-me-to-a-strong-redis-password

# 管理员初始账号（仅首次启动、账号不存在时创建）
ADMIN_USERNAME=admin
# 生产环境必须修改为强密码（至少16位，含大小写字母、数字、特殊字符）
ADMIN_PASSWORD=change-me-to-a-strong-admin-password

# ---------- 生产环境必须设置 ----------

# 站点外部 URL（用于生成考试二维码、分享链接等）
# 必须设置为实际域名，不设置则自动探测（可能不准确，不推荐用于生产）
SITE_URL=https://nurse.hospital.com

# CORS 允许的来源（逗号分隔多个域名）
# 生产环境必须设置为实际前端域名，切勿使用 *
CORS_ORIGINS=https://nurse.hospital.com

# ---------- 可选项 ----------

# MySQL 连接信息（Docker Compose 部署使用默认值即可）
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=nursespace_app
MYSQL_DATABASE=nurse_training_system

# AI 评分配置（不配置则使用本地文本匹配算法降级）
# OpenAI:
# OPENAI_API_KEY=sk-xxxx
# OPENAI_MODEL=gpt-4o-mini
# 智谱 GLM:
# ZHIPU_API_KEY=xxxx.xxxx
# ZHIPU_MODEL=glm-4-air

# 数据库连接池（每个 gunicorn worker 的连接池大小）
DB_POOL_SIZE=10
DB_POOL_RECYCLE=1800
DB_MAX_OVERFLOW=10

# Gunicorn 配置
# 3 workers × 5 threads = 15 并发处理能力
# 生产环境建议 workers = CPU 核心数 × 2 + 1
GUNICORN_WORKERS=3
GUNICORN_THREADS=5
GUNICORN_TIMEOUT=120

# JWT Token 有效期（秒），默认 3600 = 1 小时
JWT_ACCESS_TOKEN_EXPIRES=3600

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=1
RATELIMIT_ENABLED=1
RATELIMIT_STORAGE_URL=redis://redis:6379/1

# Session 安全
SESSION_COOKIE_SECURE=1

# 是否使用国内镜像加速（国内服务器设为 true，海外服务器/CI 保持 false）
USE_CHINA_MIRROR=false

# HTTPS 配置（由 Nginx 处理，此处不需要开启）
ENABLE_HTTPS=0
