# ============================================
# NurseSpace v3.0.8 — 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ⚠️ .env 包含敏感信息，绝不能提交到版本控制
# ⚠️ 生产环境必须使用随机强密码
# ============================================

# ---------- 必填项（生产环境必须修改）----------

# Flask 密钥（用于 session 签名）
# 生成方法: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# JWT 密钥（用于 Token 签名）
# 生成方法: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-another-random-string

# 加密密钥（用于加密 DB 中存储的 AI API Key）
# 生成方法: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-to-a-fernet-key

# MySQL 数据库密码
MYSQL_ROOT_PASSWORD=change-me-to-a-strong-db-root-password
MYSQL_PASSWORD=change-me-to-a-strong-db-password

# Redis 密码
REDIS_PASSWORD=change-me-to-a-strong-redis-password

# 管理员初始账号（仅首次启动、账号不存在时创建）
ADMIN_USERNAME=admin
# 生产环境必须修改为强密码（至少16位，含大小写字母、数字、特殊字符）
ADMIN_PASSWORD=change-me-to-a-strong-admin-password

# ---------- 生产环境必须设置 ----------

# 站点外部 URL（用于生成考试二维码、分享链接等）
# 必须设置为实际域名，不设置则自动探测（可能不准确，不推荐用于生产）
SITE_URL=https://nurse.hospital.com

# CORS 允许的来源（逗号分隔多个域名）
# 生产环境必须设置为实际前端域名，切勿使用 *
CORS_ORIGINS=https://nurse.hospital.com
# 仅当跨域请求必须携带 Cookie 时才设为 1，且 CORS_ORIGINS 不能为 *
CORS_SUPPORTS_CREDENTIALS=0

# ---------- 可选项 ----------

# MySQL 连接信息（Docker Compose 部署使用默认值即可）
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=nursespace_app
MYSQL_DATABASE=nurse_training_system

# AI 评分配置（不配置则使用本地文本匹配算法降级）
# OpenAI:
# OPENAI_API_KEY=sk-xxxx
# OPENAI_MODEL=gpt-4o-mini
# 智谱 GLM:
# ZHIPU_API_KEY=xxxx.xxxx
# ZHIPU_MODEL=glm-4-air

# 语音识别 — 百度 ASR（国内免费额度 5万次/天/Key）
# 可在管理员后台 → 语音设置中动态添加多个 Key，自动轮转
# 注册地址: https://console.bce.baidu.com/ai/#/ai/speech/overview
# 也可在此设置作为备用 Key（与后台 Key 同时生效）：
# BAIDU_ASR_APP_ID=your-app-id
# BAIDU_ASR_API_KEY=your-api-key
# BAIDU_ASR_SECRET_KEY=your-secret-key

# 数据库连接池（每个 gunicorn worker 的连接池大小）
DB_POOL_SIZE=10
DB_POOL_RECYCLE=1800
DB_MAX_OVERFLOW=10

# Gunicorn 配置
# 3 workers × 5 threads = 15 并发处理能力
# 生产环境建议 workers = CPU 核心数 × 2 + 1
GUNICORN_WORKERS=3
GUNICORN_THREADS=5
GUNICORN_TIMEOUT=120

# JWT Token 有效期（秒），默认 3600 = 1 小时
JWT_ACCESS_TOKEN_EXPIRES=3600

# Redis (Docker Compose 部署时由 compose 自动注入，此处可不设置)
# 非 Docker 部署需指定 Redis 连接地址和密码
# REDIS_URL=redis://:your-redis-password@redis:6379/0
REDIS_ENABLED=1
RATELIMIT_ENABLED=1
# RATELIMIT_STORAGE_URL=redis://:your-redis-password@redis:6379/1

# Session 安全
SESSION_COOKIE_SECURE=1

# 是否使用国内镜像加速（国内服务器设为 true，海外服务器/CI 保持 false）
USE_CHINA_MIRROR=false

# 默认跳过 ChromaDB ONNX 模型启动下载，避免网络问题阻塞应用启动
# 需要预热知识库检索模型时可设为 0
SKIP_CHROMA_MODEL_DOWNLOAD=1

# Nginx 域名（用于 server_name 指令，多个域名用空格分隔）
# Docker Compose 部署时自动模板化到 nginx.conf；不设置则使用 _（匹配所有）
NGINX_SERVER_NAME=nurse.hospital.com

# 日志格式：设为 json 启用结构化日志（JSON 每行一条），留空使用传统格式
LOG_FORMAT=json

# HTTPS 配置（由 Nginx 处理，此处不需要开启）
ENABLE_HTTPS=0
