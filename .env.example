# ============================================
# 护士培训系统 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ⚠️ .env 包含敏感信息，绝不能提交到版本控制
# ⚠️ 生产环境必须使用随机强密码
# ============================================

# ---------- 必填项 ----------
# Flask 密钥（用于 session 签名），生产环境必须使用随机长字符串
# 生成方法: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# JWT 密钥（用于 Token 签名），生产环境必须使用随机长字符串
# 生成方法: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-another-random-string

# MySQL 配置
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=nursespace_app
MYSQL_PASSWORD=change-me-to-a-strong-db-password
MYSQL_DATABASE=nurse_training_system

# 管理员初始账号（仅首次启动时创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-on-first-login

# ---------- 可选项 ----------
# AI 评分配置（不配置则使用本地文本匹配算法）
# OPENAI_API_KEY=sk-xxxx
# OPENAI_MODEL=gpt-4o-mini
# ZHIPU_API_KEY=xxxx.xxxx
# ZHIPU_MODEL=glm-4-air

# 数据库连接池（每个 gunicorn worker 进程的连接池大小）
DB_POOL_SIZE=10
DB_POOL_RECYCLE=1800
DB_MAX_OVERFLOW=10

# Gunicorn 配置（3 workers × 5 threads = 15 并发处理能力）
GUNICORN_WORKERS=3
GUNICORN_THREADS=5
GUNICORN_TIMEOUT=120

# JWT Token 有效期（秒），默认 3600 = 1小时
JWT_ACCESS_TOKEN_EXPIRES=3600

# Redis（用于缓存与限流）
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=1
RATELIMIT_ENABLED=1
RATELIMIT_STORAGE_URL=redis://redis:6379/1

# 文件上传目录（容器内路径，一般不需要修改）
# UPLOAD_FOLDER=/app/uploads

# 案例文档目录（容器内路径，一般不需要修改）
# CASES_DIR=/app/案例

# HTTPS 配置（一般由 Nginx 处理，此处不需要开启）
ENABLE_HTTPS=0
# HTTPS_PORT=8443
# SSL_CERT_FILE=/app/certs/server.crt
# SSL_KEY_FILE=/app/certs/server.key
